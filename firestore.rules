rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isOwner() {
      return request.auth != null
        && request.auth.token.email in [
          "v4313436@gmail.com"
        ];
    }

    match /videos/{videoId} {
      allow read: if true;
      allow create, update, delete: if isOwner();
    }
  }
}
